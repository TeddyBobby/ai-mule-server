{
  "name": "@ai-mule/server",
  "version": "0.0.1",
  "description": "AI Mule Server - Backend Service",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:services": "node -r ./dist/main.js test/manual-test-services.js",
    "test:services:ts": "ts-node -r tsconfig-paths/register test/manual-test-services.ts",
    "test:integration": "ts-node -r tsconfig-paths/register test/manual-test-integration.ts",
    "test:integration:step": "TEST_MODE=step ts-node -r tsconfig-paths/register test/manual-test-integration.ts",
    "test:integration:flow": "TEST_MODE=integration ts-node -r tsconfig-paths/register test/manual-test-integration.ts",
    "test:e2e:integration": "jest --config ./test/jest-e2e.json integration-workspace-container"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.29",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.8",
    "@types/js-yaml": "^4.0.9",
    "aws-sdk": "^2.1693.0",
    "@puuuudding/decamelize-keys": "^6.2.2",
    "@types/chokidar": "^2.1.7",
    "axios": "^1.13.2",
    "camelcase-keys": "^10.0.2",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dockerode": "^4.0.9",
    "fs-extra": "^11.3.2",
    "ioredis": "^5.8.2",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.15.3",
    "nest-winston": "^1.10.2",
    "proper-lockfile": "^4.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "totp-generator": "0.0.13",
    "typeorm": "^0.3.27",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.8",
    "@types/dockerode": "^3.3.45",
    "@types/express": "^5.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
