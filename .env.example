# ===========================================
# AI Mule Server 环境配置
# ===========================================
# 说明：本项目统一使用 Docker 环境运行
# docker-compose.yml 会覆盖部分配置（如 DB_HOST, REDIS_HOST）
# 复制此文件为 .env 并根据需要修改
# ===========================================

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=/ai_mule/web_api/v1

# Database
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123
DB_DATABASE=ai_mule_server
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Workspace（本地开发建议放在项目目录内）
WORKSPACE_ROOT=./.local-data/workspaces
WORKSPACE_IDLE_TIMEOUT=1800000
WORKSPACE_SUSPEND_TIMEOUT=7200000
WORKSPACE_ARCHIVE_TIMEOUT=259200000
WORKSPACE_MAX_PER_USER=10

# Docker
# macOS Docker Desktop 常见路径：
# DOCKER_SOCKET=/Users/<your-name>/.docker/run/docker.sock
# Linux 常见路径：
# DOCKER_SOCKET=/var/run/docker.sock
# DOCKER_ENV=true
# NGINX_WORKSPACES_DIR=/etc/nginx/workspaces
# NGINX_CONTAINER_NAME=ai-mule-server-nginx-1

# 本地开发默认关闭公司登录，直接注入一个本地用户
LOCAL_AUTH_BYPASS=true
LOCAL_DEV_USER_ID=local-dev
LOCAL_DEV_USERNAME=local-dev
LOCAL_DEV_NICKNAME=本地开发者

# 本地预览域名
PREVIEW_DOMAIN=localhost

# Container
CONTAINER_DEFAULT_IMAGE=node:18-alpine
CONTAINER_MEMORY=2g
CONTAINER_CPUS=1.0

# SSH (用于工作空间容器的 git 操作)
SSH_KEY_PATH=~/.ssh

# ===========================================
# Claude Agent SDK 配置
# ===========================================

# Claude 状态目录（用于持久化 transcript 等，不要使用 /tmp）
CLAUDE_CONFIG_DIR=./.local-data/workspaces/system/claude-config

# API 密钥（必填，用于调用 Claude API）
ANTHROPIC_API_KEY=

# 可选：自定义 API 基础地址（用于代理或私有部署）
# 默认值: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 可选：认证令牌（部分代理服务需要，会传递给 SDK 子进程）
# ANTHROPIC_AUTH_TOKEN=

# ===========================================
# Agent 行为配置
# ===========================================

# 默认模型
# 可选值: claude-sonnet-4-5-20251101, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
AGENT_DEFAULT_MODEL=claude-sonnet-4-5-20251101

# 最大对话轮次（防止无限循环）
AGENT_MAX_TURNS=100

# 最大预算（美元，超出后停止）
# AGENT_MAX_BUDGET=10.0

# 系统提示词（可选，覆盖默认提示词）
# AGENT_SYSTEM_PROMPT=You are a helpful AI coding assistant.

# 权限模式
# - default: 标准权限行为，每次操作需要确认
# - acceptEdits: 自动接受文件编辑（推荐用于 Docker 环境）
# - bypassPermissions: 绕过所有权限检查（不支持 root 用户/Docker 环境）
# - plan: 规划模式，只生成计划不执行
AGENT_PERMISSION_MODE=acceptEdits

# 工具白名单（逗号分隔，为空表示允许所有）
# AGENT_ALLOWED_TOOLS=Read,Write,Edit,Bash

# 工具黑名单（逗号分隔）
# AGENT_DISALLOWED_TOOLS=WebSearch,WebFetch

# ===========================================
# 共享 Git 身份配置（可选）
# ===========================================
# 启用共享身份后，没有个人 Git 身份的用户将使用共享身份进行 Git 操作
# 注意：共用身份但不共用目录，每个用户仍有独立的工作空间
#
# 安全说明：
# 1. 私钥文件权限必须为 600（chmod 600 /path/to/id_rsa）
# 2. 私钥不要提交到代码仓库
# 3. Docker 环境下通过 volume 挂载（已配置 ~/.ssh:/root/.ssh:ro）
# 4. 建议为共享身份创建专用的 GitLab 账号（Deploy Key 或 Service Account）

# 是否启用共享 Git 身份
SHARED_GIT_IDENTITY_ENABLED=false

# 共享 SSH 私钥路径（Docker 环境下使用容器内路径）
# 方式1：使用宿主机 ~/.ssh 挂载（已默认挂载到 /root/.ssh）
# SHARED_GIT_SSH_KEY_PATH=/root/.ssh/id_rsa
#
# 方式2：使用独立挂载的共享密钥目录（推荐）
# SHARED_GIT_SSH_KEY_PATH=/data/shared-ssh/id_rsa

# 共享 SSH 密钥宿主机目录（用于 docker-compose 挂载）
# SHARED_SSH_DIR=/data/shared-ssh


# ===========================================
# HrCore API 配置
# ===========================================
# 用于获取用户信息和检查代码权限
# TODO: 请填写以下 HrCore API 配置

# HrCore 应用密钥
HRCORE_APP_KEY=

# HrCore 应用秘钥
HRCORE_SECRET=

# HrCore API 基础地址
HRCORE_HOST=
